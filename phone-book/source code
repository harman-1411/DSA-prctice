#include <stdio.h>

int main()
{
    char name[100];  // Correct variable for name
    int age, phone, dob;
    char address[100];  // Correct variable for address

    printf("Welcome to the phone book\n\n");

    printf("MENU\n");
    printf("Press 1 to add a contact\n\n");

    int x;
    printf("Enter your choice: ");
    scanf("%d", &x);

    if(x == 1)
    {
        int y;
        printf("Enter the number of contacts to be added: ");
        scanf("%d", &y);

        if(y == 1)
        {
            printf("---------------\n");
            printf("Enter name: ");
            scanf("%s", name);  // Corrected: no & needed for arrays
            printf("Enter age: ");
            scanf("%d", &age);
            printf("Enter phone number: ");
            scanf("%d", &phone);
            printf("Enter date of birth (DDMMYYYY): ");
            scanf("%d", &dob);
            printf("Enter address: ");
            scanf(" %[^\n]%*c", address);  // This will allow spaces in the address input
            printf("---------------\n");
        }
        else if(y == 2)
        {
            // Adding second contact
            printf("---------------\n");
            printf("Enter name: ");
            scanf("%s", name);
            printf("Enter age: ");
            scanf("%d", &age);
            printf("Enter phone number: ");
            scanf("%d", &phone);
            printf("Enter date of birth (DDMMYYYY): ");
            scanf("%d", &dob);
            printf("Enter address: ");
            scanf(" %[^\n]%*c", address);
            printf("---------------\n");

            // Second contact
            printf("Enter name for second contact: ");
            scanf("%s", name);
            printf("Enter phone number: ");
            scanf("%d", &phone);
            printf("Enter date of birth (DDMMYYYY): ");
            scanf("%d", &dob);
            printf("Enter address: ");
            scanf(" %[^\n]%*c", address);
            printf("---------------\n");
        }

        // After adding contacts
        printf("Press 2 to view the entered contacts\n");
        printf("Press 3 to exit the phone book\n");

        int z;
        printf("Enter your choice: ");
        scanf("%d", &z);

        if(z == 2)
        {
            int num;
            printf("Enter the contact number to view: ");
            scanf("%d", &num);

            if(num == 1)
            {
                printf("---------------\n");
                printf("Name: %s\n", name);  // Fixed: use correct variable
                printf("Age: %d\n", age);
                printf("Phone number: %d\n", phone);
                printf("Date of Birth: %d\n", dob);
                printf("Address: %s\n", address);
                printf("---------------\n");
            }
            else if (num == 2)
            {
                printf("---------------\n");
                printf("Name: %s\n", name);
                printf("Phone number: %d\n", phone);
                printf("Date of Birth: %d\n", dob);
                printf("Address: %s\n", address);
                printf("---------------\n");
            }
        }
        else if(z == 3)
        {
            printf("Are you sure you want to close the phone book?\n");
            printf("Press 1 for Yes\n");
            printf("Press 2 for No\n");

            int ans;
            printf("Enter your choice: ");
            scanf("%d", &ans);

            if(ans == 1)
            {
                printf("The phone book has closed.\n");
                printf("Have a good day!\n");
            }
            else if(ans == 2)
            {
                printf("The phone book has not closed yet.\n");
                printf("You can continue.\n");
            }
        }
        else
        {
            printf("Invalid choice!\n");
        }
    }
    else
    {
        printf("Invalid choice!\n");
    }

    return 0;
}
